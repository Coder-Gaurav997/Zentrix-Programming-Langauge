let x = 5;
let y = 10;

echo("Math:");
echo(x + y);
echo(x * y);

let isBig = x < y;
echo(isBig);

if (x < y) {
    echo("x is smaller");
} else {
    echo("x is bigger");
}

let count = 0;

while (count < 3) {
    echo("While Loop:");
    echo(count);
    let count = count + 1;
}

for (i in 0 to 3) {
    echo("For Loop:");
    echo(i);
}

let name = input("Enter your name: ");
echo("Hello " + name);

let nothing = null;
echo(nothing);